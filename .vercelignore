# ============================================================
# .vercelignore — Archivos ignorados por Vercel en deployments
# ============================================================
# Estos archivos/carpetas NO se suben al servidor de Vercel.
#
# REGLA GENERAL: todo lo que NO necesites en producción
# debe estar acá para reducir el tamaño del deployment.
# ============================================================

# --- Archivos de entorno (NO comprometas valores reales) ---
.env
.env.*
!.env.example

# --- Dependencias (se instalan en el servidor) ---
node_modules/
.pnp/
.pnp.js

# --- Build outputs (regenerados por Vercel) ---
.next/
out/
build/
dist/

# --- Archivos de desarrollo y configuración local ---
*.local
.eslintrc*
.git/
.gitignore
.npmrc
.prettierrc*
tsconfig.json
tailwind.config.*
postcss.config.*
drizzle.config.*
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Testing ---
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
__tests__/
tests/
coverage/

# --- Scripts y herramientas de desarrollo ---
scripts/seed.ts
scripts/setup-env.sh
*.md
!README.md

# --- Bases de datos SQLite locales (si las usas) ---
*.db
*.sqlite
*.sqlite3

# --- Logs y archivos temporales ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Documentación ---
CHANGELOG.md
TODO.md
NOTES.md
ARCHITECTURE.md
